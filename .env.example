# ===== NovaBank Environment Variables =====
# Copy this file to .env and fill in the values

# JWT Secret (base64 encoded, min 256 bits)
JWT_SECRET=CHANGE_ME_TO_A_SECURE_BASE64_SECRET_MIN_256_BITS

# ===== Database =====
DB_HOST=localhost
DB_PORT=5432
DB_NAME=banking_auth
DB_USER=banking_user
DB_PASSWORD=banking_pass_123

# ===== Redis =====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_pass_123

# ===== MongoDB =====
MONGODB_URI=mongodb://localhost:27017/banking_accounts

# ===== Kafka =====
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ===== Service URLs =====
AUTH_SERVICE_URL=http://localhost:8081
ACCOUNT_SERVICE_URL=http://localhost:8083
TRANSACTION_SERVICE_URL=http://localhost:8085
NOTIFICATION_SERVICE_URL=http://localhost:8087
AI_SERVICE_URL=http://localhost:8090

# ===== Ollama (AI Service) =====
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_CHAT_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text
